# Backend Dockerfile
FROM node:24-alpine

WORKDIR /app

# Copy package files
COPY backend/package*.json ./
RUN npm ci --only=production

# Copy backend source
COPY backend/ ./

# Copy frontend build
COPY frontend/dist/ ./dist/

# Create projects directory
RUN mkdir -p /projects

# Expose port
EXPOSE 3001

# Start server
CMD ["node", "server.js"]