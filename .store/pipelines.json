      "suggestedFeatures": [
        {
          "id": "branching_narrative",
          "name": "Consequential Choices",
          "description": "Every decision ripples forward - save fuel now and starve later, rescue a stranger who might betray you, creating deeply personal story paths with no perfect playthrough",
          "priority": "high"
        },
        {
          "id": "resource_tension",
          "name": "Survival Resource Management",
          "description": "Constantly balance oxygen, food, fuel, and power - tough choices like venting a compartment to save oxygen or rationing food force impossible decisions that define your story",
          "priority": "high"
        },
        {
          "id": "crew_dynamics",
          "name": "Crew Relationships & Skills",
          "description": "Each crew member has personality, skills, and opinions - engineer fixes systems faster, medic keeps crew alive, but conflicts arise and trust must be earned through choices",
          "priority": "high"
        },
        {
          "id": "random_events",
          "name": "Procedural Space Encounters",
          "description": "Distress signals, asteroid fields, alien contacts, and derelict ships appear randomly, ensuring each playthrough feels fresh and unpredictable",
          "priority": "medium"
        },
        {
          "id": "permadeath_mode",
          "name": "Iron Captain Mode",
          "description": "Optional permadeath where poor choices end your journey permanently - heightens tension and makes every decision genuinely matter",
          "priority": "medium"
        },
        {
          "id": "typing_immersion",
          "name": "Typewriter Text Effect",
          "description": "Story text appears letter by letter with ambient ship sounds, creating cinematic tension during critical moments and dangerous encounters",
          "priority": "medium"
        },
        {
          "id": "multiple_endings",
          "name": "Divergent Endings",
          "description": "Reach Earth, colonize a new world, become space pirates, or drift forever - dramatically different conclusions based on accumulated choices and relationships",
          "priority": "low"
        },
        {
          "id": "captains_log",
          "name": "Shareable Story Export",
